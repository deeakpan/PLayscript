{
  "name": "playscript-v2-subgraph",
  "version": "0.0.1",
  "private": true,
  "description": "Indexes Playscript v2 ScriptLocked / claim / match events on Somnia for My Scripts history.",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph codegen && graph build",
    "create-local": "graph create --node http://127.0.0.1:8020/ playscript-v2-somnia",
    "deploy-local": "graph deploy --node http://127.0.0.1:8020/ --ipfs http://127.0.0.1:5001 playscript-v2-somnia",
    "deploy:somnia": "node scripts/deploy-somnia.mjs",
    "remove-local": "graph remove --node http://127.0.0.1:8020/ playscript-v2-somnia",
    "sync-abis": "node scripts/sync-abis.mjs"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.38.0",
    "matchstick-as": "^0.6.0"
  }
}
