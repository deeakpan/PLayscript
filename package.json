    "deploy:price-oracle": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy-price-oracle.ts",
    "deploy:price-oracle:somnia": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/deploy-price-oracle.ts --network somnia",
    "invoke:price-oracle": "cross-env TS_NODE_PROJECT=tsconfig.hardhat.json hardhat run scripts/invoke-price-oracle.ts"
